# ============================================
# Конфигурация базы данных
# Скопируйте этот файл в .env и измените значения
# cp .env.example .env
# ============================================

# PostgreSQL
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=parts_catalog
POSTGRES_PORT=5432

# Docker
CONTAINER_NAME=car_parts_db

# Git
GIT_REMOTE=origin

# ============================================
# ВАЖНО: Не коммите файл .env в Git!
# Он уже добавлен в .gitignore
# ============================================
